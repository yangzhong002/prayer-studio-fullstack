# ---------- shared ----------
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---------- postgres ----------
POSTGRES_DB=prayer_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/prayer_studio
PGVECTOR_CONNECTION_STRING=postgresql+psycopg://postgres:postgres@db:5432/prayer_studio

# ---------- backend ----------
# Dev: http://localhost:3000
# Prod: https://your-domain.com (comma-separated for multiple origins)
BACKEND_CORS_ORIGINS=http://localhost:3000
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_SCRIPTURE=6
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20
# Set to "production" when deploying
APP_ENV=dev

# ---------- frontend ----------
# Dev: http://localhost:8000
# Prod: https://your-domain.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Used by Next.js SSR inside the frontend container to reach the backend over the compose network.
INTERNAL_API_BASE_URL=http://backend:8000
